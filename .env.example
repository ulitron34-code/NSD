VITE_API_URL=https://TU-BACKEND-RENDER.onrender.com/api
VITE_STRIPE_PUBLIC_KEY=pk_live_o_pk_test_xxx
VITE_DEMO_MODE=false

# Optional: Sentry error tracking
VITE_SENTRY_DSN=
VITE_APP_VERSION=1.0.0

# Optional: NUXERA rebrand experience (name, logo and internal workspace).
# Off by default -- site shows NEXUS. Set to true to preview NUXERA everywhere.
VITE_NUXERA_EXPERIENCE_ENABLED=false

# Optional, only relevant when VITE_NUXERA_EXPERIENCE_ENABLED=true.
# Per-role and per-engine rollout switches for a phased NUXERA launch.
# Unset = enabled (matches current behavior). Set to "false" to hold one back.
# VITE_NUXERA_APPLICANT_ENABLED=true
# VITE_NUXERA_GRANTOR_ENABLED=true
# VITE_NUXERA_ADMIN_ENABLED=true
# VITE_NUXERA_INTELLIGENCE_ENABLED=true
# VITE_NUXERA_MARKETS_ENABLED=true
# VITE_NUXERA_STRATEGY_ENABLED=true

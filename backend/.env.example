SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_KEY=tu_supabase_anon_or_service_key
SUPABASE_SERVICE_ROLE_KEY=tu_supabase_service_role_key_solo_backend
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
NODE_ENV=development
PORT=3001
CORS_ORIGIN=http://127.0.0.1:5174,http://localhost:5174,https://tu-sitio.netlify.app
MAX_DOCUMENT_BYTES=26214400

# Sentry error monitoring (backend) — obtener en sentry.io
SENTRY_DSN=

# Optional AI document review/conversation providers (see aiJsonProvider.js).
# Anthropic/OpenAI are primary for sensitive data; Kimi/DeepSeek/NVIDIA are
# restricted to explicit low-risk anonymized tasks by nuxeraAiProviderPolicyService.js.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENAI_JSON_MODEL=gpt-4o-mini
DEEPSEEK_API_KEY=
DEEPSEEK_JSON_MODEL=deepseek-chat
KIMI_API_KEY=
KIMI_BASE_URL=https://api.moonshot.ai/v1
KIMI_JSON_MODEL=kimi-k3
NVIDIA_API_KEY=

# NUXERA controlled rollout flags (default off; see docs/nuxera-migration/docs/migration/NUXERA_ENVIRONMENT_VARIABLES.md)
NUXERA_CONVERSATION_RUNTIME_ENABLED=false
NUXERA_NOTIFICATION_DELIVERY_ENABLED=false
NUXERA_CASE_ASSIGNMENT_WRITE_ENABLED=false

# Email alerts (Resend — resend.com, free tier 3000 emails/mes)
RESEND_API_KEY=
EMAIL_FROM=NAGMAR <alertas@nagmar.com>
# Cron schedule en UTC (default: 0 14 * * * = 8:00am CST)
COMPLIANCE_CRON_SCHEDULE=0 14 * * *

# WhatsApp alerts (Twilio — twilio.com, sandbox gratuito para pruebas)
# TWILIO_WHATSAPP_FROM por defecto es el sandbox: whatsapp:+14155238886
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Optional regulatory API checks/integrations
COMPANIES_HOUSE_API_KEY=
MEXICO_RFC_API_URL=
MEXICO_RFC_API_KEY=
MEXICO_UIF_API_URL=
MEXICO_UIF_API_KEY=
# OFAC sanctions screening (SDN list) ya no requiere API key: se descarga
# gratis desde el Tesoro de EE.UU. y se cachea en memoria (ver ofacScreening.js)
EQUIFAX_API_URL=
EQUIFAX_API_KEY=
DUBAI_EMIRATES_ID_API_URL=
DUBAI_EMIRATES_ID_API_KEY=
DUBAI_TRADE_LICENSE_API_URL=
DUBAI_TRADE_LICENSE_API_KEY=
